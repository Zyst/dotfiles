syntax on

function g:HighlightEcho ()
  " Echo under mouse
  echom synIDattr(synID(line("."),col("."),1),"name")

  " Echo full group
  echo map(synstack(line('.'), col('.')), 'synIDattr(v:val, "name")')
endfunction

